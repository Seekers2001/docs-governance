#!/usr/bin/env bash
# docs-governance · pre-commit 护栏
# 固化一条最小可判定不变量：凡 staged 含代码改动的 commit，PROJECT_LOG.md 必须同批 staged（至少一行流水账）。
# 只拦这一条；MAP/STATUS 的同步交给 /governance-sync 与 /governance-audit（commit 关口卡多了会"狼来了"）。
# 豁免：只改测试/文档/治理文件 → 自动放行；真急事 git commit --no-verify 跳过（audit 会秋后算账）。
# 安装：cp 本文件到 .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
set -uo pipefail

# 没用四件套的项目，直接放行
[ -f PROJECT_LOG.md ] || exit 0

STAGED=$(git diff --cached --name-only)
[ -z "$STAGED" ] && exit 0

# LOG 已同批 staged → 放行
echo "$STAGED" | grep -qx "PROJECT_LOG.md" && exit 0

# 代码改动 = 豁免清单之外的 staged 文件（测试/文档/产物目录/治理文件/纯文档后缀 均豁免）
CODE=$(echo "$STAGED" \
  | grep -vE '^(tests?/|docs/|references/|reviews/|logs/|output/)' \
  | grep -vE '^(PROJECT_STATUS\.md|CLAUDE_MAP\.md|CLAUDE\.md|CLAUDE\.local\.md|CONTRACT\.md|README\.md|CHANGELOG\.md|LICENSE|\.gitignore)$' \
  | grep -vE '\.(md|txt)$' || true)
[ -z "$CODE" ] && exit 0

echo "✋ docs-governance：本次 commit 含代码改动，但 PROJECT_LOG.md 没有同批提交。" >&2
echo "   代码改动：" >&2
echo "$CODE" | head -5 | sed 's/^/     - /' >&2
echo "   补一行流水账（十秒钟）：" >&2
echo "     echo '## [$(date +%Y-%m-%d)] fix | 一句话说清改了什么' >> PROJECT_LOG.md && git add PROJECT_LOG.md" >&2
echo "   然后重新 git commit。真急事：git commit --no-verify（/governance-audit 会秋后算账）。" >&2
exit 1
